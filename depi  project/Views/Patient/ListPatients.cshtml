@model IEnumerable<depi__project.viewmodels.Patient.ResponsePatientVM>

@{
    ViewData["Title"] = "Patients";
}

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0 fw-bold">Search Patients</h5>
            </div>
            <div class="col-auto">
                <a asp-action="AddPatient" class="btn btn-primary">Add New Patient</a>
            </div>
        </div>
        <hr />
        <form asp-action="ListPatients" method="get" class="row g-3">
            <div class="col-md-7">
                <input type="text" name="searchTerm" class="form-control" placeholder="Search by name, phone or national ID" value="@ViewBag.SearchTerm" />
            </div>
            <div class="col-md-3">
                <select name="isvalid" class="form-select">
                    <option value="">All statuses</option>
                    <option value="true" selected="@(ViewBag.IsValid == true)">Valid</option>
                    <option value="false" selected="@(ViewBag.IsValid == false)">Inactive</option>
                </select>
            </div>
            <div class="col-md-2">
                <div class="btn-group w-100">
                    <button type="submit" class="btn btn-secondary">Search</button>
                    <a asp-action="ListPatients" class="btn btn-outline-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Gender</th>
                        <th>Date Of Birth</th>
                        <th>National ID</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@item.patientid</td>
                            <td class="fw-bold">@item.patientname</td>
                            <td>@item.phonenumber</td>
                            <td>@item.Gender</td>
                            <td>@item.datebirth.ToString("yyyy-MM-dd")</td>
                            <td>@(item.nationalid?.ToString() ?? "-")</td>
                            <td>
                                <span class="badge rounded-pill @(item.isvalid ? "bg-success" : "bg-secondary")">
                                    @(item.isvalid ? "Valid" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a asp-action="UpdatePatient" asp-route-id="@item.patientid" class="btn btn-sm btn-outline-warning">Edit</a>
                                    <a asp-action="PatientDetails" asp-route-id="@item.patientid" class="btn btn-sm btn-outline-info">Details</a>
                                    <form asp-action="RemovePatient" method="post" class="d-inline" onsubmit="return confirm('Deactivate this patient?');">
                                        <input type="hidden" name="id" value="@item.patientid" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Deactivate</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white py-3">
        @{
            var prevDisabled = (ViewBag.PageNumber <= 1) ? "disabled" : "";
            var nextDisabled = (!Model.Any() || Model.Count() < ViewBag.PageSize) ? "disabled" : "";
        }
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item @prevDisabled">
                    <a class="page-link" asp-action="ListPatients" asp-route-pageNumber="@(ViewBag.PageNumber - 1)" asp-route-pageSize="@ViewBag.PageSize" asp-route-searchTerm="@ViewBag.SearchTerm" asp-route-isvalid="@ViewBag.IsValid">Previous</a>
                </li>
                <li class="page-item disabled"><span class="page-link">Page @ViewBag.PageNumber</span></li>
                <li class="page-item @nextDisabled">
                    <a class="page-link" asp-action="ListPatients" asp-route-pageNumber="@(ViewBag.PageNumber + 1)" asp-route-pageSize="@ViewBag.PageSize" asp-route-searchTerm="@ViewBag.SearchTerm" asp-route-isvalid="@ViewBag.IsValid">Next</a>
                </li>
            </ul>
        </nav>
    </div>
</div>
