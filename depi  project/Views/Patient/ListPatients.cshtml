@model IEnumerable<depi__project.viewmodels.Patient.ResponsePatientVM>

@{
    ViewData["Title"] = "Patients";
}

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0 fw-bold"><i class="fas fa-user-injured me-2 text-primary"></i>Manage Patients</h5>
            </div>
            <div class="col-auto">
                <a asp-action="AddPatient" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i> Add New Patient
                </a>
            </div>
        </div>
        <hr />
        <form asp-action="ListPatients" method="get" class="row g-3">
            <div class="col-md-7">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="searchTerm" class="form-control bg-light border-start-0"
                           placeholder="Search by name, phone or national ID" value="@ViewBag.SearchTerm" />
                </div>
            </div>
            <div class="col-md-3">
                <select name="isvalid" class="form-select">
                    <option value="">All statuses</option>
                    <option value="true" selected="@(ViewBag.IsValid == true)">Valid</option>
                    <option value="false" selected="@(ViewBag.IsValid == false)">Inactive</option>
                </select>
            </div>
            <div class="col-md-2">
                <div class="btn-group w-100">
                    <button type="submit" class="btn btn-secondary">Search</button>
                    <a asp-action="ListPatients" class="btn btn-outline-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-user-injured fa-3x mb-3 opacity-25"></i>
                <p class="mb-0">No patients found.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Name</th>
                            <th>Phone</th>
                            <th>Gender</th>
                            <th>Date Of Birth</th>
                            <th>National ID</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">#@item.patientid</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-2 fw-bold"
                                             style="width: 34px; height: 34px; font-size: 0.85rem;">
                                            @(item.patientname?.Substring(0, 1).ToUpper() ?? "P")
                                        </div>
                                        <span class="fw-bold">@item.patientname</span>
                                    </div>
                                </td>
                                <td class="small">@item.phonenumber</td>
                                <td class="small">@item.Gender</td>
                                <td class="small">@item.datebirth.ToString("yyyy-MM-dd")</td>
                                <td class="small text-muted">@(item.nationalid?.ToString() ?? "-")</td>
                                <td>
                                    <span class="badge rounded-pill @(item.isvalid ? "bg-success" : "bg-secondary")">
                                        @(item.isvalid ? "Valid" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="PatientDetails" asp-route-id="@item.patientid"
                                           class="btn btn-sm btn-outline-info" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="UpdatePatient" asp-route-id="@item.patientid"
                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="RemovePatient" method="post" class="d-inline"
                                              onsubmit="return confirm('Deactivate this patient?');">
                                            <input type="hidden" name="id" value="@item.patientid" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Deactivate">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="card-footer bg-white py-3">
        @{
            var prevDisabled = (ViewBag.PageNumber <= 1) ? "disabled" : "";
            var nextDisabled = (!Model.Any() || Model.Count() < ViewBag.PageSize) ? "disabled" : "";
        }
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item @prevDisabled">
                    <a class="page-link" asp-action="ListPatients"
                       asp-route-pageNumber="@(ViewBag.PageNumber - 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-searchTerm="@ViewBag.SearchTerm"
                       asp-route-isvalid="@ViewBag.IsValid">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                <li class="page-item disabled"><span class="page-link">Page @ViewBag.PageNumber</span></li>
                <li class="page-item @nextDisabled">
                    <a class="page-link" asp-action="ListPatients"
                       asp-route-pageNumber="@(ViewBag.PageNumber + 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-searchTerm="@ViewBag.SearchTerm"
                       asp-route-isvalid="@ViewBag.IsValid">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>