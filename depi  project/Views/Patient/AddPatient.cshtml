@model depi__project.viewmodels.Patient.AddPatientVM

@{
    ViewData["Title"] = "Add Patient";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-user-injured me-2"></i>Add Patient</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="SaveAddPatient" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="patientname" class="form-label small fw-bold text-muted">Patient Name</label>
                            <input asp-for="patientname" class="form-control bg-light" placeholder="Enter patient name" />
                            <span asp-validation-for="patientname" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="phonenumber" class="form-label small fw-bold text-muted">Phone Number</label>
                            <input asp-for="phonenumber" class="form-control bg-light" placeholder="01xxxxxxxxx" />
                            <span asp-validation-for="phonenumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Gender" class="form-label small fw-bold text-muted"></label>
                            <select asp-for="Gender" asp-items="Html.GetEnumSelectList<depi__project.enums.Gender>()" class="form-select bg-light"></select>
                            <span asp-validation-for="Gender" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="datebirth" class="form-label small fw-bold text-muted">Date Of Birth</label>
                            <input asp-for="datebirth" type="date" class="form-control bg-light" />
                            <span asp-validation-for="datebirth" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="nationalid" class="form-label small fw-bold text-muted">National ID</label>
                            <input asp-for="nationalid" class="form-control bg-light" placeholder="14-digit national ID" />
                            <span asp-validation-for="nationalid" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="ListPatients" class="btn btn-light border text-muted">
                            <i class="fas fa-arrow-left me-1"></i> Back
                        </a>
                        <button type="submit" class="btn btn-primary px-5 fw-bold">
                            <i class="fas fa-save me-1"></i> Save Patient
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}