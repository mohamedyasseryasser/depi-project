@model depi__project.viewmodels.Patient.AddPatientVM

@{
    ViewData["Title"] = "Add Patient";
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold">Add Patient</h5>
            <a asp-action="ListPatients" class="btn btn-outline-secondary btn-sm">Back</a>
        </div>

        <form asp-action="SaveAddPatient" method="post" class="row g-3">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="col-md-6">
                <label asp-for="patientname" class="form-label">Patient Name</label>
                <input asp-for="patientname" class="form-control" />
                <span asp-validation-for="patientname" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="phonenumber" class="form-label">Phone Number</label>
                <input asp-for="phonenumber" class="form-control" />
                <span asp-validation-for="phonenumber" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Gender" class="form-label"></label>
                <select asp-for="Gender" asp-items="Html.GetEnumSelectList<depi__project.enums.Gender>()" class="form-select"></select>
                <span asp-validation-for="Gender" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="datebirth" class="form-label">Date Of Birth</label>
                <input asp-for="datebirth" type="date" class="form-control" />
                <span asp-validation-for="datebirth" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="nationalid" class="form-label">National ID</label>
                <input asp-for="nationalid" class="form-control" />
                <span asp-validation-for="nationalid" class="text-danger"></span>
            </div>
            <div class="col-12 text-end">
                <button type="submit" class="btn btn-primary">Save Patient</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
