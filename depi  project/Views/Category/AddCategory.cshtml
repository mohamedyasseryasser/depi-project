@model depi__project.viewmodels.category.AddCategoryVM

@{
    ViewData["Title"] = "Add Category";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-tags me-2"></i>Add Category</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="SaveAddCategory" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small"></div>
                    <input asp-for="user_id" type="hidden" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="cat_name" class="form-label small fw-bold text-muted">Category Name</label>
                            <input asp-for="cat_name" class="form-control bg-light" placeholder="e.g. Antibiotics" />
                            <span asp-validation-for="cat_name" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="cat_description" class="form-label small fw-bold text-muted">Description</label>
                            <textarea asp-for="cat_description" class="form-control bg-light" rows="4" placeholder="Brief description of the category"></textarea>
                            <span asp-validation-for="cat_description" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="ListCategories" class="btn btn-light border text-muted">
                            <i class="fas fa-arrow-left me-1"></i> Back
                        </a>
                        <button type="submit" class="btn btn-primary px-5 fw-bold">
                            <i class="fas fa-save me-1"></i> Save Category
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}