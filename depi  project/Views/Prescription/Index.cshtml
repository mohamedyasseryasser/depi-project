@model IEnumerable<depi__project.viewmodels.prescription.ResponsePrescriptionVM>

@{
    ViewData["Title"] = "Prescriptions";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-file-prescription me-2"></i>Manage Prescriptions</h5>
            </div>
            <div class="col-auto">
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i> Create Prescription
                </a>
            </div>
        </div>
        <hr />
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-9">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="searchTerm" class="form-control bg-light border-start-0"
                           placeholder="Patient name, phone, or notes" value="@ViewBag.SearchTerm" />
                </div>
            </div>
            <div class="col-md-3">
                <div class="btn-group w-100">
                    <button type="submit" class="btn btn-secondary">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-file-prescription fa-3x mb-3 opacity-25"></i>
                <p class="mb-0">No prescriptions found.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Visit</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">#@item.prescriptionid</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-2 fw-bold"
                                             style="width: 34px; height: 34px; font-size: 0.85rem;">
                                            @(item.patientname?.Substring(0, 1).ToUpper() ?? "P")
                                        </div>
                                        <span class="fw-bold">@item.patientname</span>
                                    </div>
                                </td>
                                <td class="small">@item.DoctorName</td>
                                <td class="small text-muted">#@item.visitid</td>
                                <td class="small">@item.prescriptiondate.ToString("yyyy-MM-dd")</td>
                                <td class="small">
                                    <span class="badge rounded-pill bg-light text-dark border">@item.prescriptionitems.Count</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@item.prescriptionid"
                                           class="btn btn-sm btn-outline-info" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.prescriptionid"
                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" class="d-inline"
                                              onsubmit="return confirm('Delete this prescription?');">
                                            <input type="hidden" name="id" value="@item.prescriptionid" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="card-footer bg-white py-3">
        @{
            var prevDisabled = (ViewBag.PageNumber <= 1) ? "disabled" : "";
            var nextDisabled = (!Model.Any() || Model.Count() < ViewBag.PageSize) ? "disabled" : "";
        }
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item @prevDisabled">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@(ViewBag.PageNumber - 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-searchTerm="@ViewBag.SearchTerm">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                <li class="page-item disabled"><span class="page-link">Page @ViewBag.PageNumber</span></li>
                <li class="page-item @nextDisabled">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@(ViewBag.PageNumber + 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-searchTerm="@ViewBag.SearchTerm">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>