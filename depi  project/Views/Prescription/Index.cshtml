@model IEnumerable<depi__project.viewmodels.prescription.ResponsePrescriptionVM>

@{
    ViewData["Title"] = "Prescriptions";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0 fw-bold">Prescriptions</h5>
            </div>
            <div class="col-auto">
                <a asp-action="Create" class="btn btn-primary">Create Prescription</a>
            </div>
        </div>
        <hr />
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-8">
                <input type="text" name="searchTerm" class="form-control" placeholder="Patient name, phone, or notes" value="@ViewBag.SearchTerm" />
            </div>
            <div class="col-md-4">
                <div class="btn-group w-100">
                    <button type="submit" class="btn btn-secondary">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Visit</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@item.prescriptionid</td>
                            <td class="fw-bold">@item.patientname</td>
                            <td>@item.DoctorName</td>
                            <td>#@item.visitid</td>
                            <td>@item.prescriptiondate.ToString("yyyy-MM-dd")</td>
                            <td>@item.prescriptionitems.Count</td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@item.prescriptionid" class="btn btn-sm btn-outline-info">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.prescriptionid" class="btn btn-sm btn-outline-warning">Edit</a>
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this prescription?');">
                                        <input type="hidden" name="id" value="@item.prescriptionid" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
