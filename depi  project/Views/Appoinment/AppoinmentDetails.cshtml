@model depi__project.viewmodels.Appoinment.ResponseAppoimentVM

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">Appointment Details</h5>
                <div>
                    <a asp-action="ListAppoinments" class="btn btn-sm btn-outline-secondary">Back to List</a>
                </div>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-sm-6">
                        <small class="text-muted text-uppercase d-block">Patient Info</small>
                        <strong class="fs-5">@(Model.Patient?.patientname ?? "N/A")</strong>
                        <div class="text-muted">Phone: @Model.PhoneNumber</div>
                    </div>
                    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
                        <small class="text-muted text-uppercase d-block">Status</small>
                        @{
                            var badgeClass = Model.status switch
                            {
                                depi__project.enums.AppointmentStatus.Pending => "bg-warning text-dark",
                                depi__project.enums.AppointmentStatus.Confirmed => "bg-primary",
                                depi__project.enums.AppointmentStatus.Completed => "bg-success",
                                depi__project.enums.AppointmentStatus.Cancelled => "bg-danger",
                                depi__project.enums.AppointmentStatus.NoShow => "bg-secondary",
                                _ => "bg-info"
                            };
                        }
                        <span class="badge rounded-pill fs-6 @badgeClass">@Model.status</span>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6 bg-light p-3 rounded border border-white">
                        <h6 class="fw-bold text-primary mb-2">Schedule Details</h6>
                        <table class="table table-sm table-borderless mb-0">
                            <tr>
                                <td class="text-muted w-50">Appointment Date:</td>
                                <td><strong>@Model.Appoinmentdate.ToString("yyyy-MM-dd")</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Start Time:</td>
                                <td>@Model.startat.ToString("HH:mm")</td>
                            </tr>
                            <tr>
                                <td class="text-muted">End Time:</td>
                                <td>@Model.endat.ToString("HH:mm")</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Last Updated:</td>
                                <td>@Model.updateat.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        </table>
                    </div>

                    <div class="col-md-6 bg-light p-3 rounded border border-white">
                        <h6 class="fw-bold text-primary mb-2">Billing & Staff</h6>
                        <table class="table table-sm table-borderless mb-0">
                            <tr>
                                <td class="text-muted w-50">Consultation Fee:</td>
                                <td><strong>$@Model.cost.ToString("F2")</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Booking Type:</td>
                                <td>@Model.type</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Doctor Name:</td>
                                <td>@Model.DoctorName</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Receptionist:</td>
                                <td>@Model.ReceptionistName</td>
                            </tr>
                        </table>
                    </div>

                    <div class="col-12 mt-3">
                        <h6 class="fw-bold text-primary mb-2">Notes</h6>
                        <div class="p-3 bg-light rounded text-dark">
                            @(string.IsNullOrWhiteSpace(Model.notes) ? "No notes added." : Model.notes)
                        </div>
                    </div>
                </div>

                @if (Model.Patient != null)
                {
                    <div class="card mt-4 border border-light shadow-sm">
                        <div class="card-body">
                            <h6 class="fw-bold text-dark mb-3">Patient Profile Preview</h6>
                            <div class="row g-2">
                                <div class="col-sm-4"><span class="text-muted">Gender:</span> @Model.Patient.Gender</div>
                                <div class="col-sm-4"><span class="text-muted">DOB:</span> @Model.Patient.datebirth.ToString("yyyy-MM-dd")</div>
                                <div class="col-sm-4"><span class="text-muted">National ID:</span> @(Model.Patient.nationalid?.ToString() ?? "-")</div>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.Visit != null)
                {
                    <div class="card mt-4 border border-success bg-light-success shadow-sm">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="fw-bold text-success mb-1">Associated Visit is In Progress/Completed</h6>
                                <small class="text-muted">Visit started on @Model.Visit.visitdate.ToString("yyyy-MM-dd HH:mm")</small>
                            </div>
                            <a asp-controller="Visit" asp-action="VisitDetails" asp-route-id="@Model.Visit.visitid" class="btn btn-success text-white btn-sm">View Visit Details</a>
                        </div>
                    </div>
                }
            </div>
            <div class="card-footer bg-white py-3 text-end">
                <div class="btn-group">
                    <a asp-action="UpdateAppoinment" asp-route-id="@Model.appoimentid" class="btn btn-warning">Edit Appointment</a>
                    <a asp-action="UpdateAppoinmentState" asp-route-id="@Model.appoimentid" class="btn btn-outline-secondary">Update Status</a>
                    @if (Model.Visit == null && Model.status != depi__project.enums.AppointmentStatus.Completed && Model.status != depi__project.enums.AppointmentStatus.Cancelled)
                    {
                        <a asp-controller="Visit" asp-action="AddVisit" asp-route-appointmentId="@Model.appoimentid" class="btn btn-success text-white">Start Clinic Visit</a>
                    }
                    <form asp-action="RemoveAppoinment" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this appointment?');">
                        <input type="hidden" name="id" value="@Model.appoimentid" />
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
