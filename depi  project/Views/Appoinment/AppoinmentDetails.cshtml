@model depi__project.viewmodels.Appoinment.ResponseAppoimentVM

@{
    ViewData["Title"] = "Appointment Details";
}

@{
    var badgeClass = Model.status switch
    {
        depi__project.enums.AppointmentStatus.Pending => "bg-warning text-dark",
        depi__project.enums.AppointmentStatus.Confirmed => "bg-primary",
        depi__project.enums.AppointmentStatus.Completed => "bg-success",
        depi__project.enums.AppointmentStatus.Cancelled => "bg-danger",
        depi__project.enums.AppointmentStatus.NoShow => "bg-secondary",
        _ => "bg-info"
    };
}

<div class="row justify-content-center">
    <div class="col-md-10">

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-calendar-check me-2"></i>Appointment Details</h5>
            </div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-sm-3 small fw-bold text-muted">Appointment ID</dt>
                    <dd class="col-sm-9">#@Model.appoimentid</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge rounded-pill @badgeClass">@Model.status</span>
                    </dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Patient</dt>
                    <dd class="col-sm-9">@(Model.Patient?.patientname ?? "N/A") <span class="text-muted">(@Model.PhoneNumber)</span></dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Doctor</dt>
                    <dd class="col-sm-9">@Model.DoctorName</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Receptionist</dt>
                    <dd class="col-sm-9">@Model.ReceptionistName</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Appointment Date</dt>
                    <dd class="col-sm-9">@Model.Appoinmentdate.ToString("yyyy-MM-dd")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Time</dt>
                    <dd class="col-sm-9">@Model.startat.ToString("HH:mm") - @Model.endat.ToString("HH:mm")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Booking Type</dt>
                    <dd class="col-sm-9">@Model.type</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Consultation Fee</dt>
                    <dd class="col-sm-9"><strong class="text-primary">$@Model.cost.ToString("F2")</strong></dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Last Updated</dt>
                    <dd class="col-sm-9">@Model.updateat.ToString("yyyy-MM-dd HH:mm")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Notes</dt>
                    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.notes) ? "No notes added." : Model.notes)</dd>
                </dl>

                <hr>

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <a asp-action="ListAppoinments" class="btn btn-light border text-muted">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                    <div class="btn-group">
                        <a asp-action="UpdateAppoinment" asp-route-id="@Model.appoimentid" class="btn btn-primary fw-bold">
                            <i class="fas fa-edit me-1"></i> Edit
                        </a>
                        <a asp-action="UpdateAppoinmentState" asp-route-id="@Model.appoimentid" class="btn btn-outline-secondary">
                            <i class="fas fa-sync me-1"></i> Update Status
                        </a>@if (Model.Visit == null && Model.status != depi__project.enums.AppointmentStatus.Completed && Model.status != depi__project.enums.AppointmentStatus.Cancelled)
                        {
                            <a asp-controller="Visit" asp-action="AddVisit" asp-route-appointmentId="@Model.appoimentid" class="btn btn-success text-white">
                                <i class="fas fa-stethoscope me-1"></i> Start Clinic Visit
                            </a>
                        }
                        <form asp-action="RemoveAppoinment" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this appointment?');">
                            <input type="hidden" name="id" value="@Model.appoimentid" />
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-1"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Patient != null)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-user-injured me-2"></i>Patient Profile</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="p-3 rounded border bg-light">
                                <div class="small text-muted mb-1"><i class="fas fa-venus-mars me-1"></i>Gender</div>
                                <div class="fw-semibold">@Model.Patient.Gender</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 rounded border bg-light">
                                <div class="small text-muted mb-1"><i class="fas fa-birthday-cake me-1"></i>Date of Birth</div>
                                <div class="fw-semibold">@Model.Patient.datebirth.ToString("yyyy-MM-dd")</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 rounded border bg-light">
                                <div class="small text-muted mb-1"><i class="fas fa-id-card me-1"></i>National ID</div>
                                <div class="fw-semibold">@(Model.Patient.nationalid?.ToString() ?? "-")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.Visit != null)
        {
            <div class="card border-0 shadow-sm mb-4 border-start border-success border-3">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-bold text-success mb-1"><i class="fas fa-check-circle me-2"></i>Associated Visit</h6>
                        <small class="text-muted">Visit started on @Model.Visit.visitdate.ToString("yyyy-MM-dd HH:mm")</small>
                    </div>
                    <a asp-controller="Visit" asp-action="VisitDetails" asp-route-id="@Model.Visit.visitid" class="btn btn-success text-white btn-sm">
                        <i class="fas fa-eye me-1"></i> View Visit Details
                    </a>
                </div>
            </div>
        }

    </div>
</div>
