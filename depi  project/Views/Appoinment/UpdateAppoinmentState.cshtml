@model depi__project.viewmodels.Appoinment.UpdateAppoinmentStateVM

@{
    ViewData["Title"] = "Update Appointment Status";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-calendar-check me-2"></i>Update Appointment Status</h5>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-info border-0 shadow-sm mb-4">
                    <div class="row">
                        <div class="col-6">
                            <span class="text-uppercase small d-block text-muted">Patient Name</span>
                            <strong>@Model.patientname</strong>
                        </div>
                        <div class="col-6">
                            <span class="text-uppercase small d-block text-muted">Phone Number</span>
                            <strong>@Model.phone</strong>
                        </div>
                    </div>
                </div>

                <form asp-action="SaveUpdateAppoinmentState" method="post">
                    <input type="hidden" asp-for="AppoinmentId" />
                    <input type="hidden" asp-for="patientname" />
                    <input type="hidden" asp-for="phone" />

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="Status" class="form-label small fw-bold text-muted">Appointment Status</label>
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<depi__project.enums.AppointmentStatus>()" class="form-select bg-light"></select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="AppoinmentDetails" asp-route-id="@Model.AppoinmentId" class="btn btn-light border text-muted">
                            <i class="fas fa-arrow-left me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary px-5 fw-bold">
                            <i class="fas fa-save me-1"></i> Update Status
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}