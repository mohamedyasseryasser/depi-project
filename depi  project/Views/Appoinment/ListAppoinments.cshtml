@model IEnumerable<depi__project.viewmodels.Appoinment.ResponseAppoimentVM>

@{
    ViewData["Title"] = "Appointments";
}

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-calendar-check me-2"></i>Manage Appointments</h5>
            </div>
            <div class="col-auto">
                <a asp-action="AddAppoinment" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i> Book Appointment
                </a>
            </div>
        </div>
        <hr />
        <form asp-action="ListAppoinments" method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label small fw-bold">Search Term</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="searchTerm" class="form-control bg-light border-start-0" placeholder="Search phone, patient name, notes..." value="@ViewBag.SearchTerm" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold">Date</label>
                <input type="date" name="date" class="form-control" value="@ViewBag.Date" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold">Status</label>
                <select name="status" class="form-select">
                    <option value="">All statuses</option>
                    @foreach (var status in Enum.GetValues(typeof(depi__project.enums.AppointmentStatus)))
                    {
                        <option value="@status" selected="@(ViewBag.Status?.ToString() == status.ToString())">@status</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <div class="btn-group w-100">
                    <button type="submit" class="btn btn-secondary">Search</button>
                    <a asp-action="ListAppoinments" class="btn btn-outline-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-calendar-check fa-3x mb-3 opacity-25"></i>
                <p class="mb-0">No appointments found.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Patient</th>
                            <th>Phone</th>
                            <th>Doctor</th>
                            <th>Date & Time</th>
                            <th>Cost</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                                var badgeClass = item.status switch
                                {
                                    depi__project.enums.AppointmentStatus.Pending => "bg-warning text-dark",
                                    depi__project.enums.AppointmentStatus.Confirmed => "bg-primary",depi__project.enums.AppointmentStatus.Completed => "bg-success",
                                    depi__project.enums.AppointmentStatus.Cancelled => "bg-danger",
                                    depi__project.enums.AppointmentStatus.NoShow => "bg-secondary",
                                    _ => "bg-info"
                                };
                            <tr>
                                <td class="ps-4 text-muted small">#@item.appoimentid</td>
                                <td class="fw-bold">@(item.Patient?.patientname ?? "N/A")</td>
                                <td class="small">@item.PhoneNumber</td>
                                <td class="small">@item.DoctorName</td>
                                <td>
                                    <div class="small fw-bold">@item.Appoinmentdate.ToString("yyyy-MM-dd")</div>
                                    <small class="text-muted">@item.startat.ToString("HH:mm") - @item.endat.ToString("HH:mm")</small>
                                </td>
                                <td class="small">$@item.cost.ToString("F2")</td>
                                <td>
                                    <span class="badge bg-light text-dark border">@item.type</span>
                                </td>
                                <td>
                                    <span class="badge rounded-pill @badgeClass">@item.status</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="AppoinmentDetails" asp-route-id="@item.appoimentid"
                                           class="btn btn-sm btn-outline-info" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="UpdateAppoinment" asp-route-id="@item.appoimentid"
                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="UpdateAppoinmentState" asp-route-id="@item.appoimentid"
                                           class="btn btn-sm btn-outline-secondary" title="Update Status">
                                            <i class="fas fa-sync"></i>
                                        </a>
                                        @if (item.status != depi__project.enums.AppointmentStatus.Completed && item.status != depi__project.enums.AppointmentStatus.Cancelled)
                                        {
                                            <a asp-controller="Visit" asp-action="AddVisit" asp-route-appointmentId="@item.appoimentid"
                                               class="btn btn-sm btn-success text-white" title="Start Visit">
                                                <i class="fas fa-stethoscope"></i>
                                            </a>
                                        }
                                        <form asp-action="RemoveAppoinment" method="post" class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to delete this appointment?');">
                                            <input type="hidden" name="id" value="@item.appoimentid" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="card-footer bg-white py-3">
        @{
            var prevDisabled = (ViewBag.PageNumber <= 1) ? "disabled" : "";
            var nextDisabled = (Model == null || !Model.Any() || Model.Count() < ViewBag.PageSize) ? "disabled" : "";
        }
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item @prevDisabled">
                    <a class="page-link" asp-action="ListAppoinments"
                       asp-route-pageNumber="@(ViewBag.PageNumber - 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-searchTerm="@ViewBag.SearchTerm"
                       asp-route-phone="@ViewBag.Phone"
                       asp-route-date="@ViewBag.Date"
                       asp-route-status="@ViewBag.Status">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                <li class="page-item disabled"><span class="page-link">Page @ViewBag.PageNumber</span></li>
                <li class="page-item @nextDisabled">
                    <a class="page-link" asp-action="ListAppoinments"
                       asp-route-pageNumber="@(ViewBag.PageNumber + 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-searchTerm="@ViewBag.SearchTerm"
                       asp-route-phone="@ViewBag.Phone"
                       asp-route-date="@ViewBag.Date"
                       asp-route-status="@ViewBag.Status">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>