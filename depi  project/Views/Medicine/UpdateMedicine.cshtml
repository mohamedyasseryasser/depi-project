@model depi__project.viewmodels.medicine.UpdateMedicineVM

@{
    ViewData["Title"] = "Update Medicine";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-pills me-2"></i>Update Medicine</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="SaveUpdateMedicine" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small"></div>
                    <input asp-for="medicineId" type="hidden" />
                    <input asp-for="user_id" type="hidden" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="Name" class="form-control bg-light" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SupplierName" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="SupplierName" class="form-control bg-light" />
                            <span asp-validation-for="SupplierName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="StockQuantity" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="StockQuantity" type="number" class="form-control bg-light" />
                            <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="RecordLevel" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="RecordLevel" type="number" class="form-control bg-light" />
                            <span asp-validation-for="RecordLevel" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="UnitPrice" class="form-label small fw-bold text-muted"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">$</span>
                                <input asp-for="UnitPrice" type="number" step="0.01" class="form-control bg-light" />
                            </div>
                            <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ExpiryDate" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="ExpiryDate" type="date" class="form-control bg-light" />
                            <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="cat_id" class="form-label small fw-bold text-muted">Category</label>
                            <select asp-for="cat_id" asp-items="Model.Categories" class="form-select bg-light">
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="cat_id" class="text-danger small"></span>
                        </div>
                    </div><div class="row">
                    <div class="col-md-12 mb-4">
                        <div class="form-check">
                            <input asp-for="IsDeleted" class="form-check-input" />
                            <label asp-for="IsDeleted" class="form-check-label small fw-bold text-muted">Mark as Deleted</label>
                        </div>
                    </div>
                </div>

                <hr>

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="MedicineDetails" asp-route-id="@Model.medicineId" class="btn btn-light border text-muted">
                        <i class="fas fa-arrow-left me-1"></i> Back
                    </a>
                    <button type="submit" class="btn btn-primary px-5 fw-bold">
                        <i class="fas fa-save me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
