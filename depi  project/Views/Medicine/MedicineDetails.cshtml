@model depi__project.viewmodels.medicine.ResponseMedicineVM

@{
    ViewData["Title"] = "Medicine Details";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-pills me-2"></i>Medicine Details</h5>
            </div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-sm-3 small fw-bold text-muted">Medicine ID</dt>
                    <dd class="col-sm-9">#@Model.medicineId</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Name</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge rounded-pill @(!Model.IsDeleted ? "bg-success" : "bg-danger")">
                            @(!Model.IsDeleted ? "Active" : "Deleted")
                        </span>
                    </dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Category</dt>
                    <dd class="col-sm-9">
                        <span class="badge rounded-pill bg-info bg-opacity-10 text-info">
                            @Model.CategoryName
                        </span>
                    </dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Supplier</dt>
                    <dd class="col-sm-9">@Model.SupplierName</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Stock Quantity</dt>
                    <dd class="col-sm-9">
                        @if (Model.StockQuantity <= Model.RecordLevel)
                        {
                            <span class="text-danger fw-semibold">
                                @Model.StockQuantity <small>(Low Stock!)</small>
                            </span>
                        }
                        else
                        {
                            <span class="text-success fw-semibold">@Model.StockQuantity</span>
                        }
                    </dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Reorder Level</dt>
                    <dd class="col-sm-9">@Model.RecordLevel</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Unit Price</dt>
                    <dd class="col-sm-9 fw-semibold">@Model.UnitPrice.ToString("F2") EGP</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Expiry Date</dt>
                    <dd class="col-sm-9">
                        @if (Model.ExpiryDate < DateTime.Now)
                        {
                            <span class="text-danger fw-semibold">
                                @Model.ExpiryDate.ToString("yyyy-MM-dd") <small>(Expired!)</small>
                            </span>
                        }
                        else
                        {
                            @Model.ExpiryDate.ToString("yyyy-MM-dd")
                        }
                    </dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Added By</dt>
                    <dd class="col-sm-9">@(Model.AddedBy ?? "-")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Created At</dt>
                    <dd class="col-sm-9 text-muted">@Model.CreatedAt.ToString("yyyy-MM-dd")</dd>
                </dl>

                <hr>

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="ListMedicines" class="btn btn-light border text-muted">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>@if (!Model.IsDeleted)
                    {
                        <a asp-action="UpdateMedicine" asp-route-id="@Model.medicineId" class="btn btn-primary px-5 fw-bold">
                            <i class="fas fa-edit me-1"></i> Edit
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
