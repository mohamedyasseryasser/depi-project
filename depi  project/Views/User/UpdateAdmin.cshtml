@model depi__project.viewmodels.userviewmodel.updateadminviewmodel

@{
    ViewData["Title"] = "Update Admin";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-user-shield me-2"></i>Update Admin</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="SaveUpdateAdmin">
                    <div asp-validation-summary="All" class="text-danger mb-4 small"></div>
                    <input type="hidden" asp-for="userid" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UserName" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="UserName" class="form-control bg-light" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="Email" class="form-control bg-light" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="address" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="address" class="form-control bg-light" />
                            <span asp-validation-for="address" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PhoneNumber" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="PhoneNumber" class="form-control bg-light" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Gender" class="form-label small fw-bold text-muted"></label>
                            <select asp-for="Gender" class="form-select bg-light">
                                <option value="">-- Select Gender --</option>
                                <option value="1">Male</option>
                                <option value="2">Female</option>
                            </select>
                            <span asp-validation-for="Gender" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="permissions" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="permissions" class="form-control bg-light" />
                            <span asp-validation-for="permissions" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="IsActive" />
                                <label class="form-check-label small fw-bold text-muted">@Html.DisplayNameFor(model => model.IsActive)</label>
                            </div>
                        </div>
                    </div>

                    <hr><div class="d-flex justify-content-between align-items-center">
                    <a asp-action="ListAdmins" class="btn btn-light border text-muted">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                    <button type="submit" class="btn btn-primary px-5 fw-bold">
                        <i class="fas fa-save me-1"></i> Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
