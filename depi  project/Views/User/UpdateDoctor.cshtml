@model depi__project.viewmodels.userviewmodel.updatedoctorviewmodel

@{
    ViewData["Title"] = "Update Doctor";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-user-md me-2"></i>Update Doctor</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="SaveUpdateDoctor">
                    <div asp-validation-summary="All" class="text-danger mb-4 small"></div>
                    <input type="hidden" asp-for="userid" />
                    <input type="hidden" asp-for="DoctorId" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UserName" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="UserName" class="form-control bg-light" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="Email" class="form-control bg-light" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="address" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="address" class="form-control bg-light" />
                            <span asp-validation-for="address" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PhoneNumber" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="PhoneNumber" class="form-control bg-light" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Gender" class="form-label small fw-bold text-muted"></label>
                            <select asp-for="Gender" class="form-select bg-light">
                                <option value="">-- Select Gender --</option>
                                <option value="1">Male</option>
                                <option value="2">Female</option>
                            </select>
                            <span asp-validation-for="Gender" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Specialization" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="Specialization" class="form-control bg-light" />
                            <span asp-validation-for="Specialization" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="DepartmentId" class="form-label small fw-bold text-muted"></label>
                            <select asp-for="DepartmentId" asp-items="Model.deptids" class="form-select bg-light">
                                <option value="">-- Select Department --</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                        </div>
                    </div><div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="hiredate" class="form-label small fw-bold text-muted"></label>
                        <input asp-for="hiredate" type="date" class="form-control bg-light" />
                        <span asp-validation-for="hiredate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="salary" class="form-label small fw-bold text-muted"></label>
                        <input asp-for="salary" class="form-control bg-light" />
                        <span asp-validation-for="salary" class="text-danger small"></span>
                    </div>
                </div>

                <hr>

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="ListDoctors" class="btn btn-light border text-muted">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                    <button type="submit" class="btn btn-primary px-5 fw-bold">
                        <i class="fas fa-save me-1"></i> Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}