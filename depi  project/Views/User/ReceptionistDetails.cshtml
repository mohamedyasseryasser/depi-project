@model depi__project.viewmodels.userviewmodel.responsereceptionistviewmodel

@{
    ViewData["Title"] = "Receptionist Details";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-user-tie me-2"></i>Receptionist Details</h5>
            </div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-sm-3 small fw-bold text-muted">Username</dt>
                    <dd class="col-sm-9">@Model.UserName</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Email</dt>
                    <dd class="col-sm-9">@Model.Email</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Phone Number</dt>
                    <dd class="col-sm-9">@Model.PhoneNumber</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Address</dt>
                    <dd class="col-sm-9">@Model.address</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Gender</dt>
                    <dd class="col-sm-9">@Model.Gender</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Salary</dt>
                    <dd class="col-sm-9">@Model.salary.ToString("C")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Hire Date</dt>
                    <dd class="col-sm-9">@Model.hiredate.ToLongDateString()</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Status</dt>
                    <dd class="col-sm-9">@Model.status</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Is Active</dt>
                    <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
                </dl>

                <hr>

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="ListReceptionists" class="btn btn-light border text-muted">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                    <a asp-action="UpdateReceptionist" asp-route-id="@Model.resptionistid" class="btn btn-primary px-5 fw-bold">
                        <i class="fas fa-edit me-1"></i> Edit
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>