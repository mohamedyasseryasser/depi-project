@model IEnumerable<depi__project.viewmodels.departmentvm.ResponseDeptVm>

@{
    ViewData["Title"] = "Departments";
}

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0 fw-bold"><i class="fas fa-building me-2 text-primary"></i>Manage Departments</h5>
            </div>
            <div class="col-auto">
                <a asp-action="AddDepartment" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i> Add New Department
                </a>
            </div>
        </div>
        <hr />
        <form asp-action="ListDepartments" method="get" class="row g-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="name" class="form-control bg-light border-start-0" placeholder="Department name" value="@ViewBag.Name" />
                </div>
            </div>
            <div class="col-md-3">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-phone text-muted"></i></span>
                    <input type="text" name="phone" class="form-control bg-light border-start-0" placeholder="Phone" value="@ViewBag.Phone" />
                </div>
            </div>
            <div class="col-md-3">
                <select name="isactive" class="form-select">
                    <option value="">All statuses</option>
                    <option value="true" selected="@(ViewBag.IsActive == true)">Active</option>
                    <option value="false" selected="@(ViewBag.IsActive == false)">Inactive</option>
                </select>
            </div>
            <div class="col-md-2">
                <div class="btn-group w-100">
                    <button type="submit" class="btn btn-secondary">Search</button>
                    <a asp-action="ListDepartments" class="btn btn-outline-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-building fa-3x mb-3 opacity-25"></i>
                <p class="mb-0">No departments found.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Name</th>
                            <th>Floor</th>
                            <th>Phone</th>
                            <th>Doctors</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">#@item.DepartmentId</td>
                                <td class="fw-bold">@item.Name</td>
                                <td class="small">@item.FloorNumber</td>
                                <td class="small">@item.Phone</td>
                                <td>
                                    <span class="badge bg-light text-dark border">@item.DoctorCount</span>
                                </td>
                                <td>
                                    <span class="badge rounded-pill @(item.isactive ? "bg-success" : "bg-secondary")">
                                        @(item.isactive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="DepartmentDetails" asp-route-id="@item.DepartmentId"
                                           class="btn btn-sm btn-outline-info" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="UpdateDepartment" asp-route-id="@item.DepartmentId"
                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="RemoveDepartment" method="post" class="d-inline"
                                              onsubmit="return confirm('Deactivate this department?');">
                                            <input type="hidden" name="id" value="@item.DepartmentId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Deactivate">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="card-footer bg-white py-3">
        @{
            var prevDisabled = (ViewBag.PageNumber <= 1) ? "disabled" : "";
            var nextDisabled = (!Model.Any() || Model.Count() < ViewBag.PageSize) ? "disabled" : "";
        }
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item @prevDisabled">
                    <a class="page-link" asp-action="ListDepartments"
                       asp-route-pageNumber="@(ViewBag.PageNumber - 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-name="@ViewBag.Name"
                       asp-route-phone="@ViewBag.Phone"
                       asp-route-isactive="@ViewBag.IsActive">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                <li class="page-item disabled"><span class="page-link">Page @ViewBag.PageNumber</span></li>
                <li class="page-item @nextDisabled">
                    <a class="page-link" asp-action="ListDepartments"
                       asp-route-pageNumber="@(ViewBag.PageNumber + 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-name="@ViewBag.Name"
                       asp-route-phone="@ViewBag.Phone"
                       asp-route-isactive="@ViewBag.IsActive">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>
