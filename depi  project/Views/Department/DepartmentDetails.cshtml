@model depi__project.viewmodels.departmentvm.ResponseDeptVm

@{
    ViewData["Title"] = "Department Details";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-hospital-alt me-2"></i>Department Details</h5>
            </div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-sm-3 small fw-bold text-muted">Department Name</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Department ID</dt>
                    <dd class="col-sm-9">#@Model.DepartmentId</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Floor</dt>
                    <dd class="col-sm-9">@Model.FloorNumber</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Phone</dt>
                    <dd class="col-sm-9">@Model.Phone</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Created At</dt>
                    <dd class="col-sm-9">@Model.createdat.ToString("yyyy-MM-dd")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Description</dt>
                    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.description) ? "No description" : Model.description)</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge rounded-pill @(Model.isactive ? "bg-success" : "bg-secondary")">
                            @(Model.isactive ? "Active" : "Inactive")
                        </span>
                    </dd>
                </dl>

                <hr>

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="ListDepartments" class="btn btn-light border text-muted">
                        <i class="fas fa-arrow-left me-1"></i> Back
                    </a>
                    <a asp-action="UpdateDepartment" asp-route-id="@Model.DepartmentId" class="btn btn-primary px-5 fw-bold">
                        <i class="fas fa-edit me-1"></i> Edit
                    </a>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-user-md me-2"></i>Doctors</h5>
                <span class="badge rounded-pill bg-primary-subtle text-primary fw-bold">@Model.doctors.Count() Total</span>
            </div>
            <div class="card-body p-4">
                @if (Model.doctors.Any())
                {
                    <div class="row g-3">
                        @foreach (var doctor in Model.doctors)
                        {
                            <div class="col-md-6">
                                <div class="d-flex align-items-center p-3 rounded border bg-light">
                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold me-3"
                                         style="width:48px;height:48px;min-width:48px;font-size:1.1rem;">
                                        @(doctor.UserName?.Substring(0, 1).ToUpper())
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-bold">@doctor.UserName</div>
                                        <div class="text-muted small"><i class="fas fa-envelope me-1"></i>@doctor.Email</div>
                                        <div class="text-muted small"><i class="fas fa-stethoscope me-1"></i>@doctor.Specialization</div>
                                    </div>
                                    <span class="badge rounded-pill @(doctor.status == depi__project.enums.userstatus.active ? "bg-success" : "bg-secondary")">
                                        @doctor.status
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No doctors assigned yet.</p>
                }
            </div>
        </div>
    </div>
</div>