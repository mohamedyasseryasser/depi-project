@model depi__project.viewmodels.departmentvm.UpdateDertVm

@{
    ViewData["Title"] = "Update Department";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-hospital-alt me-2"></i>Update Department</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="SaveUpdateDepartment" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small"></div>
                    <input asp-for="DepartmentId" type="hidden" />
                    <input asp-for="userid" type="hidden" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="Name" class="form-control bg-light" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="FloorNumber" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="FloorNumber" class="form-control bg-light" />
                            <span asp-validation-for="FloorNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="Phone" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="Phone" class="form-control bg-light" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="description" class="form-label small fw-bold text-muted"></label>
                            <textarea asp-for="description" class="form-control bg-light" rows="4"></textarea>
                            <span asp-validation-for="description" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <div class="form-check">
                                <input asp-for="isactive" class="form-check-input" />
                                <label asp-for="isactive" class="form-check-label small fw-bold text-muted">Active</label>
                            </div>
                        </div>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="DepartmentDetails" asp-route-id="@Model.DepartmentId" class="btn btn-light border text-muted">
                            <i class="fas fa-arrow-left me-1"></i> Back
                        </a>
                        <button type="submit" class="btn btn-primary px-5 fw-bold">
                            <i class="fas fa-save me-1"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}