@model depi__project.viewmodels.Visit.ResponseVisitVM

@{
    ViewData["Title"] = "Visit Details";
}

@{
    var badgeClass = Model.visitstatus switch
    {
        depi__project.enums.VisitStatus.InProgress => "bg-warning text-dark",
        depi__project.enums.VisitStatus.Completed => "bg-success",
        _ => "bg-secondary"
    };
}

<div class="row justify-content-center">
    <div class="col-md-10">

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-clipboard-list me-2"></i>Visit Details</h5>
            </div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-sm-3 small fw-bold text-muted">Visit ID</dt>
                    <dd class="col-sm-9">#@Model.visitid</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Appointment</dt>
                    <dd class="col-sm-9">
                        <a asp-controller="Appoinment" asp-action="AppoinmentDetails" asp-route-id="@Model.appoinmentid">#@Model.appoinmentid</a>
                    </dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge rounded-pill @badgeClass">@Model.visitstatus</span>
                    </dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Patient</dt>
                    <dd class="col-sm-9">
                        @(Model.ResponseAppoimentVM?.Patient?.patientname ?? "N/A")
                        <span class="text-muted">(@(Model.ResponseAppoimentVM?.PhoneNumber ?? "N/A"))</span>
                    </dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Doctor</dt>
                    <dd class="col-sm-9">@(Model.ResponseAppoimentVM?.DoctorName ?? "N/A")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Visit Date</dt>
                    <dd class="col-sm-9">@Model.visitdate.ToString("yyyy-MM-dd")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Consultation Fee</dt>
                    <dd class="col-sm-9"><strong class="text-primary">$@(Model.ResponseAppoimentVM?.cost.ToString("F2") ?? "0.00")</strong></dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Diagnosis</dt>
                    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.diagnosis) ? "No diagnosis recorded yet." : Model.diagnosis)</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Notes</dt>
                    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.notes) ? "No notes recorded yet." : Model.notes)</dd>
                </dl>

                <hr>

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <a asp-action="ListVisits" class="btn btn-light border text-muted">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                    <div class="btn-group">
                        <a asp-action="UpdateVisit" asp-route-id="@Model.visitid" class="btn btn-primary fw-bold">
                            <i class="fas fa-edit me-1"></i> Edit
                        </a>
                        <form asp-action="RemoveVisit" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this visit record?');">
                            <input type="hidden" name="id" value="@Model.visitid" />
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-1"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-file-medical me-2"></i>Prescription</h5>
                        @if (Model.Prescription != null)
                        {
                            <span class="badge rounded-pill bg-success">Generated</span>
                        }
                        else
                        {
                            <span class="badge rounded-pill bg-secondary">Pending</span>
                        }
                    </div>
                    <div class="card-body p-4">
                        @if (Model.Prescription != null)
                        {
                            <dl class="row mb-2">
                                <dt class="col-sm-4 small fw-bold text-muted">Date</dt>
                                <dd class="col-sm-8">@Model.Prescription.prescriptiondate.ToString("yyyy-MM-dd")</dd>

                                <dt class="col-sm-4 small fw-bold text-muted">Instructions</dt>
                                <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Prescription.notes) ? "—" : Model.Prescription.notes)</dd>
                            </dl>

                            @if (Model.Prescription.items != null && Model.Prescription.items.Any())
                            {
                                <hr />
                                <p class="small fw-bold text-muted mb-2">Medicines</p>
                                <ul class="list-group list-group-flush">
                                    @foreach (var item in Model.Prescription.items)
                                    {
                                        <li class="list-group-item px-0 py-1 small d-flex justify-content-between">
                                            <span><i class="fas fa-pills text-primary me-1"></i>@item.Medicine?.Name</span>
                                            <span class="text-muted">Qty: @item.quantity</span>
                                        </li>
                                    }
                                </ul>
                            }
                        }
                        else
                        {
                            <p class="text-muted small">No prescription has been created for this visit yet.</p>
                            <a href="/Prescription/AddPrescription?visitId=@Model.visitid" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-plus me-1"></i> Add Prescription
                            </a>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-file-invoice-dollar me-2"></i>Invoice</h5>
                        @if (Model.Invoice != null)
                        {
                            <span class="badge rounded-pill bg-success">@Model.Invoice.Status</span>
                        }
                        else
                        {
                            <span class="badge rounded-pill bg-secondary">Unpaid</span>
                        }
                    </div>
                    <div class="card-body p-4">
                        @if (Model.Invoice != null)
                        {
                            <dl class="row mb-0">
                                <dt class="col-sm-4 small fw-bold text-muted">Invoice ID</dt>
                                <dd class="col-sm-8">#@Model.Invoice.InvoiceId</dd>
                                <dt class="col-sm-4 small fw-bold text-muted">Total</dt>
                                <dd class="col-sm-8"><strong class="text-primary">$@Model.Invoice.FinalAmount.ToString("F2")</strong></dd>

                                <dt class="col-sm-4 small fw-bold text-muted">Issued</dt>
                                <dd class="col-sm-8">@Model.Invoice.CreatedAt.ToString("yyyy-MM-dd")</dd>
                            </dl>
                        }
                        else
                        {
                            <p class="text-muted small">No invoice has been generated for this visit yet.</p>
                            <a href="/Invoice/CreateInvoice?visitId=@Model.visitid" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-plus me-1"></i> Generate Invoice
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>