@model depi__project.viewmodels.Visit.AddVisit

@{
    ViewData["Title"] = "Start Clinic Visit";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-clipboard-list me-2"></i>Start Clinic Visit</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="SaveAddVisit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small"></div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="appoinmentid" class="form-label small fw-bold text-muted">Select Scheduled Appointment</label>
                            @if (Model.appoinmentid > 0)
                            {
                                <input type="hidden" asp-for="appoinmentid" />
                                <div class="form-control bg-light">
                                    Appointment ID: <strong>#@Model.appoinmentid</strong> (Pre-selected)
                                </div>
                            }
                            else
                            {
                                <select asp-for="appoinmentid" asp-items="ViewBag.Appointments" class="form-select bg-light">
                                    <option value="">-- Select Appointment --</option>
                                </select>
                            }
                            <span asp-validation-for="appoinmentid" class="text-danger small"></span>
                            <div class="form-text text-muted small">Only appointments marked as Pending/Confirmed and without an active visit will appear.</div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="diagnosis" class="form-label small fw-bold text-muted">Diagnosis / Chief Complaint</label>
                            <input asp-for="diagnosis" class="form-control bg-light" placeholder="e.g. Chronic seasonal allergy, migraine" />
                            <span asp-validation-for="diagnosis" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="notes" class="form-label small fw-bold text-muted">Physician Notes</label>
                            <textarea asp-for="notes" rows="4" class="form-control bg-light" placeholder="Describe symptoms, temperature, blood pressure, or general exam notes..."></textarea>
                            <span asp-validation-for="notes" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="ListVisits" class="btn btn-light border text-muted">
                            <i class="fas fa-arrow-left me-1"></i> Back
                        </a>
                        <button type="submit" class="btn btn-primary px-5 fw-bold">
                            <i class="fas fa-save me-1"></i> Start Visit
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}