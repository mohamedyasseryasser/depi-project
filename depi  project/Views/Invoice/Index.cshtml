@model IEnumerable<depi__project.viewmodels.invoice.ResponseInvoiceVM>

@{
    ViewData["Title"] = "Invoices";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0 fw-bold">Invoices</h5>
            </div>
            <div class="col-auto">
                <a asp-action="Create" class="btn btn-primary">Create Invoice</a>
            </div>
        </div>
        <hr />
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-5">
                <input type="text" name="searchTerm" class="form-control" placeholder="Patient name, phone, or invoice ID" value="@ViewBag.SearchTerm" />
            </div>
            <div class="col-md-4">
                <select name="status" class="form-select" asp-items="Html.GetEnumSelectList<depi__project.enums.InvoiceStatus>()">
                    <option value="">All statuses</option>
                </select>
            </div>
            <div class="col-md-3">
                <div class="btn-group w-100">
                    <button type="submit" class="btn btn-secondary">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Patient</th>
                        <th>Visit</th>
                        <th>Total</th>
                        <th>Final</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@item.InvoiceId</td>
                            <td class="fw-bold">@item.PatientName</td>
                            <td>#@item.VisitId</td>
                            <td>$@item.TotalAmount.ToString("F2")</td>
                            <td><strong>$@item.FinalAmount.ToString("F2")</strong></td>
                            <td>
                                <span class="badge rounded-pill @(item.Status == depi__project.enums.InvoiceStatus.Paid ? "bg-success" : item.Status == depi__project.enums.InvoiceStatus.Cancelled ? "bg-secondary" : "bg-warning text-dark")">
                                    @item.Status
                                </span>
                            </td>
                            <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@item.InvoiceId" class="btn btn-sm btn-outline-info">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.InvoiceId" class="btn btn-sm btn-outline-warning">Edit</a>
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this invoice?');">
                                        <input type="hidden" name="id" value="@item.InvoiceId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
