@model IEnumerable<depi__project.viewmodels.invoice.ResponseInvoiceVM>

@{
    ViewData["Title"] = "Invoices";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-file-invoice-dollar me-2"></i>Manage Invoices</h5>
            </div>
            <div class="col-auto">
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i> Create Invoice
                </a>
            </div>
        </div>
        <hr />
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="searchTerm" class="form-control bg-light border-start-0"
                           placeholder="Patient name, phone, or invoice ID" value="@ViewBag.SearchTerm" />
                </div>
            </div>
            <div class="col-md-4">
                <select name="status" class="form-select" asp-items="Html.GetEnumSelectList<depi__project.enums.InvoiceStatus>()">
                    <option value="">All statuses</option>
                </select>
            </div>
            <div class="col-md-3">
                <div class="btn-group w-100">
                    <button type="submit" class="btn btn-secondary">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-file-invoice-dollar fa-3x mb-3 opacity-25"></i>
                <p class="mb-0">No invoices found.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Patient</th>
                            <th>Visit</th>
                            <th>Total</th>
                            <th>Final</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">#@item.InvoiceId</td>
                                <td class="fw-bold">@item.PatientName</td>
                                <td class="small text-muted">#@item.VisitId</td>
                                <td class="small">$@item.TotalAmount.ToString("F2")</td>
                                <td><strong class="text-primary">$@item.FinalAmount.ToString("F2")</strong></td>
                                <td>
                                    <span class="badge rounded-pill @(item.Status == depi__project.enums.InvoiceStatus.Paid ? "bg-success" : item.Status == depi__project.enums.InvoiceStatus.Cancelled ? "bg-secondary" : "bg-warning text-dark")">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="small text-muted">@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@item.InvoiceId"
                                           class="btn btn-sm btn-outline-info" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.InvoiceId"
                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" class="d-inline"
                                              onsubmit="return confirm('Delete this invoice?');">
                                            <input type="hidden" name="id" value="@item.InvoiceId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="card-footer bg-white py-3">
        @{
            var prevDisabled = (ViewBag.PageNumber <= 1) ? "disabled" : "";
            var nextDisabled = (!Model.Any() || Model.Count() < ViewBag.PageSize) ? "disabled" : "";
        }
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item @prevDisabled">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@(ViewBag.PageNumber - 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-searchTerm="@ViewBag.SearchTerm"
                       asp-route-status="@ViewBag.Status">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                <li class="page-item disabled"><span class="page-link">Page @ViewBag.PageNumber</span></li>
                <li class="page-item @nextDisabled">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@(ViewBag.PageNumber + 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-searchTerm="@ViewBag.SearchTerm"
                       asp-route-status="@ViewBag.Status">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>