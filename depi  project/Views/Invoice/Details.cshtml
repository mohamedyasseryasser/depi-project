@model depi__project.viewmodels.invoice.ResponseInvoiceVM

@{
    ViewData["Title"] = "Invoice Details";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary"><i class="fas fa-file-invoice me-2"></i>Invoice Details</h5>
            </div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-sm-3 small fw-bold text-muted">Invoice ID</dt>
                    <dd class="col-sm-9">#@Model.InvoiceId</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge rounded-pill @(Model.Status == depi__project.enums.InvoiceStatus.Paid ? "bg-success" : Model.Status == depi__project.enums.InvoiceStatus.Cancelled ? "bg-secondary" : "bg-warning text-dark")">
                            @Model.Status
                        </span>
                    </dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Visit</dt>
                    <dd class="col-sm-9">
                        <a asp-controller="Visit" asp-action="VisitDetails" asp-route-id="@Model.VisitId">Visit #@Model.VisitId</a>
                        <span class="text-muted">(@Model.VisitDate.ToString("yyyy-MM-dd"))</span>
                    </dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Patient</dt>
                    <dd class="col-sm-9">@Model.PatientName <span class="text-muted">(@Model.PatientPhone)</span></dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Doctor</dt>
                    <dd class="col-sm-9">@Model.DoctorName</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Appointment</dt>
                    <dd class="col-sm-9">#@(Model.AppointmentId?.ToString() ?? "N/A")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Total Amount</dt>
                    <dd class="col-sm-9">$@Model.TotalAmount.ToString("F2")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Tax</dt>
                    <dd class="col-sm-9">$@Model.Tax.ToString("F2")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Discount</dt>
                    <dd class="col-sm-9">$@Model.Discount.ToString("F2")</dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Final Amount</dt>
                    <dd class="col-sm-9"><strong class="text-primary fs-5">$@Model.FinalAmount.ToString("F2")</strong></dd>

                    <dt class="col-sm-3 small fw-bold text-muted">Created At</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>

                <hr>

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-light border text-muted">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.InvoiceId" class="btn btn-primary px-5 fw-bold">
                        <i class="fas fa-edit me-1"></i> Edit
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>